[Unit]
Description=Claude Channel Plugin Daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/data/tools/trading-claude
ExecStart=/bin/bash /data/tools/trading-claude/scripts/claude_daemon.sh
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
